{
	"name": "pageflare",
	"version": "1.0.0",
	"description": "Framework integrations for Pageflare static site optimization",
	"type": "module",
	"license": "MIT",
	"homepage": "https://pageflare.dev",
	"repository": {
		"type": "git",
		"url": "https://github.com/getappz/pageflare-cli"
	},
	"bugs": {
		"url": "https://github.com/getappz/pageflare-cli/issues"
	},
	"exports": {
		"./vite": {
			"import": "./dist/vite.js",
			"types": "./dist/vite.d.ts"
		},
		"./nuxt": {
			"import": "./dist/nuxt.js",
			"types": "./dist/nuxt.d.ts"
		},
		"./astro": {
			"import": "./dist/astro.js",
			"types": "./dist/astro.d.ts"
		},
		"./next": {
			"import": "./dist/next.js",
			"types": "./dist/next.d.ts"
		},
		"./netlify": {
			"import": "./dist/netlify.js",
			"types": "./dist/netlify.d.ts"
		}
	},
	"main": "./dist/netlify.js",
	"files": [
		"dist/",
		"manifest.yml"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@nuxt/kit": ">=3.0.0",
		"astro": ">=4.0.0",
		"next": ">=13.0.0",
		"vite": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		},
		"@nuxt/kit": {
			"optional": true
		},
		"astro": {
			"optional": true
		},
		"next": {
			"optional": true
		}
	},
	"optionalDependencies": {
		"@pageflare/cli-darwin-arm64": "^0.4.0",
		"@pageflare/cli-darwin-x64": "^0.4.0",
		"@pageflare/cli-linux-arm64": "^0.4.0",
		"@pageflare/cli-linux-arm64-musl": "^0.4.0",
		"@pageflare/cli-linux-x64": "^0.4.0",
		"@pageflare/cli-linux-x64-musl": "^0.4.0",
		"@pageflare/cli-win32-x64": "^0.4.0"
	},
	"devDependencies": {
		"@nuxt/kit": "^3.0.0",
		"@nuxt/schema": "^3.21.2",
		"@types/node": "^22.0.0",
		"astro": "^5.0.0",
		"next": "^15.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.6.0",
		"vite": "^6.0.0"
	},
	"keywords": [
		"pageflare",
		"pagespeed",
		"performance",
		"optimization",
		"vite-plugin",
		"nuxt-module",
		"astro-integration",
		"nextjs",
		"static-site"
	]
}
