{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"esModuleInterop": true,
		"declaration": true,
		"lib": ["ES2022"],
		"paths": {
			"@nuxt/schema": ["./node_modules/@nuxt/schema"]
		}
	},
	"include": ["src/**/*"]
}
